# v02 — Environment-Variablen
# Kopiere zu .env, fülle Werte ein. .env wird NIE committet.

# Postgres (lokal via docker-compose, Production via IONOS-VPS)
DATABASE_URL=postgres://wachsam:wachsam_dev@localhost:5432/wachsam

# Auth.js v5
AUTH_SECRET=          # `openssl rand -base64 32`
AUTH_URL=http://localhost:3000

# Resend (Magic-Link + Notifications)
RESEND_API_KEY=       # https://resend.com/api-keys
AUTH_EMAIL_FROM=wachsam@ruhrlogik.de

# App-Mode
NODE_ENV=development
