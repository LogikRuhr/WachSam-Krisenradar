# WachSam Intelligence Pipeline — .env
# Kopiere nach .env und fülle die Werte aus.
# .env ist gitignored — NIEMALS ins Repo committen.

# Database (gleiche Instanz wie v02/)
POSTGRES_URL=postgresql://wachsam:wachsam_dev@localhost:5432/wachsam

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=wachsam-prod
VERTEX_AI_LOCATION=europe-west3
# Modell bewusst konfigurierbar halten, damit Retirement/Versionwechsel keinen Code-Change brauchen.
GEMINI_MODEL_NAME=gemini-2.5-flash
# Lokal bevorzugt: ADC via `gcloud auth application-default login`, dann leer lassen.
# Lokales Keyfile nur ausserhalb des Repos speichern, z.B.
# %USERPROFILE%\.config\wachsam\secrets\wachsam-intelligence-key.json
# Prod-Containerpfad bei v02/infra/docker-compose.intelligence.prod.yml:
# /opt/wachsam/secrets/wachsam-intelligence-key.json
GOOGLE_APPLICATION_CREDENTIALS=

# Structured Sources
DESTATIS_USERNAME=
DESTATIS_PASSWORD=
GIE_API_KEY=
EIA_API_KEY=
# Tankerkoenig (Kraftstoffpreise) — kostenloser Key: creativecommons.tankerkoenig.de
TANKERKOENIG_API_KEY=

# Allgemein
ENVIRONMENT=development
DEBUG=true
